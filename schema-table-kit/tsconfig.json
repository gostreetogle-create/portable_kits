{
  "compileOnSave": false,
  "compilerOptions": {
    "outDir": "./dist/out-tsc",
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "moduleResolution": "bundler",
    "importHelpers": true,
    "target": "ES2022",
    "module": "ES2022",
    "lib": ["ES2022", "dom"],
    "baseUrl": ".",
    "paths": {
      "tslib": ["node_modules/tslib"],
      "@angular/*": ["../node_modules/@angular/*"],
      "@schema-table-kit/core": ["src/core/index.ts"],
      "@schema-table-kit/angular": ["src/angular/index.ts"],
      "@schema-table-kit/express": ["src/express/index.ts"],
      "@sortable-kit/angular": ["../sortable-kit/src/angular/index.ts"],
      "@options-resolver-kit/core": ["../options-resolver-kit/src/core/index.ts"],
      "@options-resolver-kit/angular": ["../options-resolver-kit/src/angular/index.ts"],
      "@entity-picker-kit/core": ["../entity-picker-kit/src/core/index.ts"],
      "@entity-picker-kit/angular": ["../entity-picker-kit/src/angular/index.ts"],
      "@schema-data-table-kit/core": ["../schema-data-table-kit/src/core/index.ts"],
      "@schema-data-table-kit/angular": ["../schema-data-table-kit/src/angular/index.ts"],
      "@crud-factory-kit/core": ["../crud-factory-kit/src/core/index.ts"],
      "@crud-factory-kit/express": ["../crud-factory-kit/src/express/index.ts"],
      "@photo-uploader-kit/core": ["../photo-uploader-kit/src/core/index.ts"],
      "@photo-uploader-kit/angular": ["../photo-uploader-kit/src/angular/index.ts"],
      "@placeholder-kit/core": ["../placeholder-kit/src/core/index.ts"],
      "@placeholder-kit/angular": ["../placeholder-kit/src/angular/index.ts"],
      "@document-canvas-kit/core": ["../document-canvas-kit/src/core/index.ts"],
      "@document-canvas-kit/angular": ["../document-canvas-kit/src/angular/index.ts"],
      "@ui-primeng-kit/core": ["../ui-primeng-kit/src/core/index.ts"],
      "@ui-primeng-kit/angular": ["../ui-primeng-kit/src/angular/index.ts"],
      "@crud-page-kit/core": ["../crud-page-kit/src/core/index.ts"],
      "@crud-page-kit/angular": ["../crud-page-kit/src/angular/index.ts"],
      "@eav-kit/core": ["../eav-kit/src/core/index.ts"],
      "@eav-kit/angular": ["../eav-kit/src/angular/index.ts"],
      "@auth-rbac-kit/core": ["../auth-rbac-kit/src/core/index.ts"],
      "@auth-rbac-kit/angular": ["../auth-rbac-kit/src/angular/index.ts"],
      "@layout-shell-kit/core": ["../layout-shell-kit/src/core/index.ts"],
      "@layout-shell-kit/angular": ["../layout-shell-kit/src/angular/index.ts"],
      "@quotation-editor/core": ["../quotation-editor/src/core/index.ts"],
      "@quotation-editor/angular": ["../quotation-editor/src/angular/index.ts"]
    }
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictTemplates": true
  }
}
